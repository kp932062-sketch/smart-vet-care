MYSQL_HOST=127.0.0.1
MYSQL_PORT=3310
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=smartvet
MYSQL_CONNECTION_LIMIT=10

DB_HOST=127.0.0.1
DB_PORT=3310
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=smartvet

JWT_SECRET=your-super-secure-jwt-secret-key-here

PORT=5000
PORT_FALLBACK_ATTEMPTS=10
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=500

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password-here

RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,application/pdf

ADMIN_EMAIL=admin@smartvet.com
ADMIN_PASSWORD=ChangeMeToAStrongPassword

DATABASE_URL=mysql://your_db_user:your_db_password@127.0.0.1:3310/smartvet
